# Copy to /etc/seserver.env and edit. setup.sh installs a default if missing.

# --- Behind a Cloudflare Tunnel (edge terminates TLS): serve plain ws locally ---
SECHAT_DEV_INSECURE=1

# --- OR direct wss (no tunnel): comment the line above and set a real cert ---
# TLS_CERT=/etc/seserver/cert.pem
# TLS_KEY=/etc/seserver/key.pem

# UDP STUN responder port (only useful when the box is reachable over UDP)
# STUN_PORT=3478

# Verbose logging
# SECHAT_DEBUG=1
